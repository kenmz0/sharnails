.home-main {
    margin-top: var(--height-header);
    height: auto;
}

.poster {
    position: relative;
    height: calc(100vh - var(--height-header));
    width: 100%;
    display: grid;
    grid-template-rows: 3fr 1fr 1fr;
    place-items: center center;
}

.poster .background-item {
    position: absolute;
    height: 100%;
    width: 100%;
    top: 0;
    left: 0;
    background-color: #6a448827;
    filter: opacity(0.8);
    overflow: hidden;
    pointer-events: none;
}

.poster .background-item img {
    opacity: 1;
    position: absolute;
}

.poster .background-item img:nth-of-type(1) {
    height: 60%;
    left: 0;
    top: 45%;
    transform: translateX(-100%) scale(1.3);
    animation: fade-in 1s forwards, panning-to-right 1s forwards;
}

.poster .background-item img:nth-of-type(2) {
    height: 50%;
    right: 0;
    top: 50%;
    transform: translateX(100%);
    animation: fade-in 1s forwards, panning-to-left 1s forwards;
}

.poster .background-item .mask {
    height: 100%;
    width: 100%;
    top: 0;
    left: 0;
    z-index: 10;
    position: absolute;
    background-color: #ffffff27;
    pointer-events: none;
}

.poster .img-logo {
    margin: auto;
    z-index: 100;
    animation: fade-in 1.2s forwards;
}

.href-cursos {
    text-transform: uppercase;
    height: 60px;
    padding: 10px 30px;
    background-color: #000;
    color: white;
    border: 1px solid var(--accent-color);
    display: grid;
    place-items: center center;
    border-radius: 30px;
    animation: fade-in 2s forwards;
    font-weight: bold;
    font-family: 'Lucida Sans Unicode', 'Lucida Grande', 'Lucida Sans', Arial, sans-serif;
    transition: background-color 0.19s ease-in-out;
    text-decoration: none;
    text-align: center;
}


.href-cursos:hover {
    background-color: white;
    color: #000;
    cursor: pointer;
}

.redes-sociales {
    position: relative;
    z-index: 1;
}

.redes-sociales ul {
    display: flex;
    list-style: none;
    gap: 10px;
    padding: 0;
}

.redes-sociales a {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    text-align: center;
    color: black;
    text-decoration: none;
}

.redes-sociales .icon {
    height: 30px;
    --width: 30px;
    width: 30px;
    background: url('../img/icons.webp');
    background-repeat: no-repeat;
    background-size: cover;
}

.redes-sociales a:hover .icon {
    transform: scale(1.05);
}

.redes-sociales .icon-tk {
    background-position: calc(-1 * var(--width) * 2) 0;
}

.redes-sociales .icon-i {
    background-position: calc(-1 * var(--width) * 1) 0;
}

.redes-sociales .icon-yt {
    background-position: calc(-1 * var(--width) * 4) 0;
}

.redes-sociales .icon-fb {
    background-position: calc(-1 * var(--width) * 0) 0;
}

.redes-sociales .icon-pin {
    background-position: calc(-1 * var(--width) * 3) 0;
}
